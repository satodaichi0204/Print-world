<!-- ===== Print World ヘッダー（ページテーマ「ヘッダ」Twig 貼り付け用） ===== -->
<!-- 私たちの fv-header デザイン + MTのカート/ログイン/SPメニュー/ロゴ(wa_top)。 -->
<!-- このTwigが全ページ共通でCSSを読み込む（フッターもこのCSSで描画される）。 -->
<link rel="stylesheet" href="https://print-world-blond.vercel.app/styles.css">
<link rel="stylesheet" href="https://print-world-blond.vercel.app/mobile.css">
<script>document.body.classList.add("product-list-page");</script>
{% set siteInfo = getSiteInfo(app.request) %}
<header class="fv-header">
  <div class="fv-header__left">
    <a class="fv-logo" href="{{ path('wa_top') }}">
      <img src="https://print-world.jp/resource/8b3f34795c5d0e55433f3256bee16c1784081172" width="320" height="auto" alt="{{ siteInfo.title }}" decoding="async" />
    </a>
    <div class="fv-header__brand">
      <p class="fv-header__brand-lead">はじめてのオリジナルTシャツは</p>
      <p class="fv-header__brand-name">プリントワールド</p>
    </div>
  </div>

  <div class="fv-header__right">
    <div class="fv-header__actions">
      <div class="fv-header__main">
        <p class="fv-pill" role="note">相談しながら作りたい人はこちら！</p>
        <div class="fv-header__links">
          <a class="phone-box" href="tel:0566785885">
            <span class="phone-box__body">
              <span class="phone-box__top">
                <img class="phone-box__icon" src="https://print-world.jp/resource/3d10dcc6323b529c8ac4371e1e02f61784081138" alt="" aria-hidden="true" />
                <span class="phone-box__number">0566-78-5885</span>
              </span>
              <span class="phone-box__label">電話受付:平日 9:00〜17:30</span>
            </span>
          </a>
          <a class="cta cta--contact" href="#">
            <img class="cta__icon" src="https://print-world.jp/resource/a485b21712e525b9444204dd0291e81784080979" alt="" aria-hidden="true" />
            <span class="cta__label">お問い合わせ</span>
          </a>
          <a class="cta cta--line" href="#" rel="noopener">
            <img class="cta__icon" src="https://print-world.jp/resource/6f75a7c39a3e5574b25eb8b08298091784080930" alt="" aria-hidden="true" />
            <span class="cta__label">LINE相談</span>
          </a>
        </div>
      </div>
      <nav class="fv-header__compact" aria-label="お問い合わせ">
        <a class="fv-compact-action fv-compact-action--phone" href="tel:0566785885">
          <img src="https://print-world.jp/resource/e1a24921127e176de01f51f04fec4e1784081153" alt="" width="32" height="32" aria-hidden="true" />
          <span>お電話</span>
        </a>
        <a class="fv-compact-action fv-compact-action--mail" href="#">
          <img src="https://print-world.jp/resource/f7867a0b86e20db39663860d3937231784080995" alt="" width="32" height="32" aria-hidden="true" />
          <span>お問合せ</span>
        </a>
        <a class="fv-compact-action fv-compact-action--line" href="#" rel="noopener">
          <img src="https://print-world.jp/resource/b5b3902e4d093b4e0f36008ef8c0b01784080952" alt="" width="32" height="32" aria-hidden="true" />
          <span>LINE</span>
        </a>
      </nav>

      <!-- ===== MT機能クラスタ（カート＋ログイン）: MTの正確なマークアップを維持 ===== -->
      <div class="mt-ec">
        <div class="header__item header__cart js-num">
          <a href="{{ path('wa_cart') }}"><i class="m-icon icon--cart"></i></a>
          <i class="header__icon m-icon icon--count is-show" id="js-cart-count"></i>
        </div>
        <div class="header__item header__login">
          <span class="m-btn btn--login js-login js-modal" data-modal="loginModal">ログイン</span>
          <span class="m-btn btn--user js-subMenuShow">
            <img src="/img/spacer.gif" class="js-header-username-image" width="34" height="34" alt="">
          </span>
          <nav class="m-listMenu listMenu--login js-subMenu">
            <div class="listMenu__inner">
              <ul class="listMenu__area js-header-account-dropdown-menu">
                <li class="listMenu__item">
                  <a href="{{ path('wa_my_page_account') }}" class="listMenu__lnk">アカウント情報</a>
                </li>
                <li class="listMenu__item">
                  <a href="{{ path('fos_user_security_logout') }}" class="listMenu__lnk">ログアウト</a>
                </li>
              </ul>
            </div>
          </nav>
        </div>
      </div>

      <!-- ハンバーガー: 私たちのデザインのまま、MTのSPメニューを開く -->
      <button type="button" class="menu-btn js-openSpMenu" aria-label="メニューを開く" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
